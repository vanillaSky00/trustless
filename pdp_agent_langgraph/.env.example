# Zero Trust PDP Agent — Environment Configuration
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

# -----------------------------------------------------------------------------
# Required — LLM provider (used for PEP validator and LangMem extraction)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# Model used by the agent for the PEP validator LLM call
# gpt-4o-mini is recommended: cheap, fast, JSON-mode capable
ZT_PDP_LLM_MODEL=gpt-4o-mini

# Model used by LangMem for memory extraction
ZT_PDP_MEMORY_MODEL=gpt-4o-mini

# Embedding model used by langmem InMemoryStore for semantic memory search
ZT_PDP_EMBEDDING_MODEL=text-embedding-3-small
ZT_PDP_EMBEDDING_DIMS=1536

# -----------------------------------------------------------------------------
# Optional — Agent thresholds
# -----------------------------------------------------------------------------

# Risk score (0.0–1.0) at or above this triggers DENY
ZT_PDP_DENY_THRESHOLD=0.75

# Risk score (0.0–1.0) at or above this (but below DENY) triggers STEP-UP
ZT_PDP_STEPUP_THRESHOLD=0.45

# Number of recent turns retained in short-term session memory
ZT_PDP_SESSION_WINDOW=8

# Max number of memories LangMem returns per semantic search
ZT_PDP_MEMORY_K=5

# -----------------------------------------------------------------------------
# Optional — Behavior toggles
# -----------------------------------------------------------------------------

# If true, the LLM PEP validator runs even on low-pattern-score requests
# (catches semantic attacks that pattern matching misses; costs more $)
ZT_PDP_LLM_VALIDATE_ALWAYS=false

# If true, log full agent state at every node transition (verbose debugging)
ZT_PDP_DEBUG=false

# -----------------------------------------------------------------------------
# Optional — LangSmith tracing (free tier available)
# Uncomment to enable trace visualization at https://smith.langchain.com
# -----------------------------------------------------------------------------
# LANGSMITH_API_KEY=ls_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=zt-pdp-agent
